# OS filesystem
.DS_Store

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Claude Code (local, machine-specific overrides — keep settings.json tracked)
.claude/settings.local.json

# Sublime Test
*.sublime-project
*.sublime-workspace

# Temporary folder
tmp/

# Course textbooks & lecture notes: keep the folders (via .gitkeep), but ignore
# their contents (downloaded books, slides, notes — large and re-downloadable).
written/*/textbooks/*
!written/*/textbooks/.gitkeep
written/*/lecture-notes/*
!written/*/lecture-notes/.gitkeep
