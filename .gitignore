# OS filesystem
.DS_Store

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Claude Code (local, machine-specific overrides — keep settings.json tracked)
.claude/settings.local.json

# Sublime Test
*.sublime-project
*.sublime-workspace

# Temporary folder
tmp/

# Course resources: keep each folder skeleton (via .gitkeep), but ignore its
# contents (downloaded books, slides, notes — large and re-downloadable). One
# rule covers every institution/publications folder, including any added later.
written/*/resource/*/*
!written/*/resource/*/.gitkeep
